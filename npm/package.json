{
  "name": "@gofsd/shmring",
  "version": "0.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Cross-thread/cross-tab shared-memory ring buffer for the browser (SharedArrayBuffer-backed), compiled from the same Rust crate as the native backend via wasm-bindgen",
  "type": "module",
  "main": "shmring.js",
  "exports": {
    ".": "./shmring.js"
  },
  "files": [
    "shmring.js",
    "shmring_wasm.js",
    "shmring_wasm_bg.wasm",
    "README.md"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gofsd/shmring.git",
    "directory": "web"
  },
  "homepage": "https://github.com/gofsd/shmring#web",
  "bugs": "https://github.com/gofsd/shmring/issues",
  "license": "MIT",
  "keywords": [
    "shared-memory",
    "ring-buffer",
    "wasm",
    "webassembly",
    "sharedarraybuffer",
    "worker"
  ],
  "engines": {
    "node": ">=18"
  }
}
